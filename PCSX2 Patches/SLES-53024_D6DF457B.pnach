[Speed up Fix to 60 FPS]
author=Puggsy, Claude AI & Google Gemini
description= Fix the Speed up, there is a 1-frame "running in place" stutter. This stutter is a native engine animation blending delay, stretched to 60fps

// Physical Nudge Throttle (Speed up fix)
// Hook
patch=1,EE,00182b50,word,0803C040 // j 0x000F0100
patch=1,EE,00182b54,word,00000000 // nop
// Syncs physical translation velocity to 60fps using the same internal parity.
patch=1,EE,000F0100,word,8E022E38 // lw v0, 0x2e38(s0)
patch=1,EE,000F0104,word,30420001 // andi v0, v0, 1
patch=1,EE,000F0108,word,14400003 // bne v0, zero, 0x000F011C
patch=1,EE,000F010C,word,00000000 // nop
patch=1,EE,000F0110,word,8E020018 // lw v0, 0x18(s0)
patch=1,EE,000F0114,word,24420001 // addiu v0, v0, 1
patch=1,EE,000F0118,word,AE020018 // sw v0, 0x18(s0)
patch=1,EE,000F011C,word,08060AD8 // j 0x00182b60
patch=1,EE,000F0120,word,00000000 // nop
